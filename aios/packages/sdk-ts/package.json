{
  "name": "aios-sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the AIOS multi-agent population operations platform",
  "license": "SEE LICENSE IN README.md",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": ["dist/src"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test \"dist/tests/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": ["aios", "multi-agent", "llm-ops", "agent-operations", "sdk"]
}
